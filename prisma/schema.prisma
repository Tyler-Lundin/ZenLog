datasource db {
    provider = "mongodb"
    url      = env("DATABASE_URL")
}

generator client {
    provider = "prisma-client-js"
}

model User {
    id        String     @id @default(auto()) @map("_id") @db.ObjectId
    email     String     @unique
    username  String     @unique
    password  String
    years     Year[]
    createdAt DateTime   @default(now())
    updatedAt DateTime   @updatedAt
    Exercise  Exercise[]
}

model Year {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    year      Int
    months    Month[]
    user      User     @relation(fields: [userId], references: [id])
    userId    String   @map("userId") @db.ObjectId
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Month {
    id     String @id @default(auto()) @map("_id") @db.ObjectId
    month  Int
    userId String @map("userId") @db.ObjectId
    year   Year   @relation(fields: [yearId], references: [id])
    yearId String @map("yearId") @db.ObjectId
    weeks  Week[]
}

model Week {
    id      String @id @default(auto()) @map("_id") @db.ObjectId
    week    Int
    userId  String @map("userId") @db.ObjectId
    Days    Day[]
    month   Month  @relation(fields: [monthId], references: [id])
    monthId String @db.ObjectId
}

model Day {
    id            String          @id @default(auto()) @map("_id") @db.ObjectId
    day           Int
    userId        String          @map("userId") @db.ObjectId
    week          Week            @relation(fields: [weekId], references: [id])
    weekId        String          @map("weekId") @db.ObjectId
    ExerciseEntry ExerciseEntry[]
    FoodEntry     FoodEntry[]
    WaterEntry    WaterEntry[]
    SleepEntry    SleepEntry[]
    JournalEntry  JournalEntry[]
    MoodEntry     MoodEntry[]
    MeditateEntry MeditateEntry[]
}

model ExerciseEntry {
    id         String @id @default(auto()) @map("_id") @db.ObjectId
    exerciseId String @db.ObjectId
    reps       Int
    weight     Int
    day        Day    @relation(fields: [dayId], references: [id])
    dayId      String @db.ObjectId
}

model Exercise {
    id               String    @id @default(auto()) @map("_id") @db.ObjectId
    name             String
    aliases          String[]
    primaryMuscles   Muscle[]
    secondaryMuscles Muscle[]
    force            Force
    level            Level
    mechanic         Mechanic
    equipment        Equipment
    category         Category
    instructions     String[]
    description      String
    tips             String[]
    createdBy        User      @relation(fields: [createdById], references: [id])
    createdById      String    @db.ObjectId
}

enum Muscle {
    ABS
    HAMSTRINGS
    CALVES
    SHOULDERS
    ADDUCTORS
    GLUTES
    QUADRICEPS
    BICEPS
    FOREARMS
    ABDUCTORS
    TRICEPS
    CHEST
    LOWER_BACK
    TRAPS
    MIDDLE_BACK
    LATS
    NECK
}

enum Force {
    PULL
    PUSH
    STATIC
}

enum Level {
    BEGINNER
    INTERMEDIATE
    EXPERT
}

enum Mechanic {
    COMPOUND
    ISOLATION
}

enum Equipment {
    BARBELL
    DUMBBELL
    BODYWEIGHT
    MACHINE
    CABLE
    BAND
    KETTLEBELL
    MEDICINE_BALL
    CARDIO
    OTHER
}

enum Category {
    STRENGTH
    STRETCHING
    PLYOMETRICS
    STRONGMAN
    POWERLIFTING
    CARDIO
    OLYMPIC_WEIGHTLIFTING
    CROSSFIT
    WEIGHTED_BODYWEIGHT
    ASSISTED_BODYWEIGHT
}

model FoodEntry {
    id          String       @id @default(auto()) @map("_id") @db.ObjectId
    day         Day          @relation(fields: [dayId], references: [id])
    dayId       String       @db.ObjectId
    name        String
    ingredients Ingredient[]
    rating      Int
}

type Ingredient {
    name          String
    calories      Int
    servingSizeG  Int
    fatTotalG     Int
    fatSaturatedG Int
    proteinG      Int
    sodiumMG      Int
    potassiumMG   Int
    cholesterolMG Int
    carbsG        Int
    fiberG        Int
    sugarsG       Int
}

model SleepEntry {
    id    String @id @default(auto()) @map("_id") @db.ObjectId
    hours Int
    day   Day    @relation(fields: [dayId], references: [id])
    dayId String @db.ObjectId
}

model JournalEntry {
    id    String @id @default(auto()) @map("_id") @db.ObjectId
    text  String
    day   Day    @relation(fields: [dayId], references: [id])
    dayId String @db.ObjectId
}

model MoodEntry {
    id    String @id @default(auto()) @map("_id") @db.ObjectId
    mood  String
    day   Day    @relation(fields: [dayId], references: [id])
    dayId String @db.ObjectId
}

model WaterEntry {
    id     String @id @default(auto()) @map("_id") @db.ObjectId
    amount Int
    unit   String
    day    Day    @relation(fields: [dayId], references: [id])
    dayId  String @db.ObjectId
}

model MeditateEntry {
    id      String @id @default(auto()) @map("_id") @db.ObjectId
    minutes Int
    day     Day    @relation(fields: [dayId], references: [id])
    dayId   String @db.ObjectId
}
